# Meta / WhatsApp
META_APP_SECRET=your_meta_app_secret_here
META_ACCESS_TOKEN=your_meta_access_token_here
META_PHONE_NUMBER_ID=your_phone_number_id_here
META_VERIFY_TOKEN=your_custom_verify_token_here   # any random string you choose

# Allowlist — comma-separated E.164 numbers
ALLOWED_PHONE_NUMBERS=+14085551234

# AI
ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=tvly-...

# Database
DATABASE_URL=postgresql://localhost/assistant

# Set this after running ngrok
NGROK_URL=https://your-ngrok-subdomain.ngrok-free.app
