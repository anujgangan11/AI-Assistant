#!/usr/bin/env bash
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'
log()  { echo -e "${GREEN}▶${NC} $*"; }
warn() { echo -e "${YELLOW}⚠${NC} $*"; }
die()  { echo -e "${RED}✗${NC} $*" >&2; exit 1; }

PIDS=()

cleanup() {
    echo ""
    log "Stopping all services..."
    for pid in "${PIDS[@]:-}"; do
        kill "$pid" 2>/dev/null || true
    done
    wait 2>/dev/null || true
}
trap cleanup EXIT INT TERM

# ── preflight ──────────────────────────────────────────────────────────────
[[ -f .env ]]                 || die ".env not found — copy .env.example and configure it"
[[ -d .venv ]]                || die ".venv not found — run: python3 -m venv .venv && pip install -r requirements.txt"
[[ -d sidecar/node_modules ]] || die "node_modules missing — run: cd sidecar && npm install"
command -v ollama > /dev/null || die "ollama not found — install from https://ollama.com"
command -v node   > /dev/null || die "node not found — install Node.js 18+"

# Wait for a service to become ready, with a timeout.
wait_for() {
    local url=$1 name=$2 timeout=${3:-30}
    local i=0
    until curl -sf --max-time 2 "$url" > /dev/null 2>&1; do
        sleep 1; i=$((i+1))
        [[ $i -ge $timeout ]] && die "$name did not become ready after ${timeout}s"
    done
}

# ── 1. Main Ollama — LLM (:11434) ─────────────────────────────────────────
if curl -sf --max-time 2 http://localhost:11434/api/tags > /dev/null 2>&1; then
    log "Main Ollama (:11434) already running"
else
    warn "Main Ollama not running — starting it (logs: /tmp/ollama-llm.log)"
    ollama serve >> /tmp/ollama-llm.log 2>&1 &
    PIDS+=($!)
    wait_for http://localhost:11434/api/tags "Main Ollama" 30
    log "Main Ollama ready"
fi

# ── 2. Embed Ollama — nomic-embed-text (:11435) ───────────────────────────
if curl -sf --max-time 2 http://localhost:11435/api/tags > /dev/null 2>&1; then
    log "Embed Ollama (:11435) already running"
else
    log "Starting embed Ollama (:11435)... (logs: /tmp/ollama-embed.log)"
    OLLAMA_HOST=127.0.0.1:11435 ollama serve >> /tmp/ollama-embed.log 2>&1 &
    PIDS+=($!)
    wait_for http://localhost:11435/api/tags "Embed Ollama" 30
    log "Embed Ollama ready"
fi

# ── 3. Baileys sidecar ─────────────────────────────────────────────────────
# Delete stale Signal session files — they cause "Waiting for this message"
# decryption errors after every sidecar restart. Bailing deletes re-negotiates
# fresh sessions on first contact; creds.json and pre-keys are left intact.
if ls sidecar/auth/session-*.json > /dev/null 2>&1; then
    count=$(ls sidecar/auth/session-*.json | wc -l | tr -d ' ')
    rm -f sidecar/auth/session-*.json
    log "Cleared $count stale Signal session file(s)"
fi

log "Starting Baileys sidecar..."
(cd sidecar && node index.js) &
PIDS+=($!)
sleep 2

# ── 4. Python worker ───────────────────────────────────────────────────────
log "Starting Python worker..."
source .venv/bin/activate
python -m src.queue.worker &
PIDS+=($!)

echo ""
log "All services up. Ctrl+C to stop everything."
echo ""
wait
